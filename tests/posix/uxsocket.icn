
$include "posix.icn"
link io

procedure main()
   # tempname() uses getenv("TEMP") / /tmp / "." and the right path separator (see io.icn).
   sock := tempname("unicon-uxsocket-", "")
   if fork() ~== 0 then {
      # parent
      delay(1000)
      f := open(sock, "n") |
         stop("Couldn't connect: ",  sys_errstr(&errno))

      write(f, "hello, world!")
      write(read(f))

      delay(1000)
      close(f)
      exit(0)
   }

   # child
   if f := open(sock, "na") then {
      if fork() = 0 then {
         handle(f)
         close(f)
         exit(0)
      }
      close(f)
      system("rm -f " || sock)
   }
   (&errno = 0) | stop("Couldn't accept: ", sys_errstr(&errno))
end
   
procedure handle(f)
   while line := read(f) do
      write(f, reverse(line))
end

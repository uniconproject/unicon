   method test_launch()
      local args, msg

      write("\nTEST launch\n")

      args := table()
      args["program"] := "../progs/complex_ex.icn"

      send_request("launch", args)

      msg := expect_response("launch") | stop("launch failed")

      write("response:")
      write(tojson(msg))

      drain_messages(200)
      return self
   end

   method test_configurationDone()
      local msg

      write("\nTEST configurationDone\n")

      send_request("configurationDone", table())

      msg := expect_response("configurationDone") | stop("configurationDone failed")

      write("response:")
      write(tojson(msg))

      drain_messages(200)
      return self
   end

   method test_continue()
      local args, msg

      write("\nTEST continue\n")

      args := table()
      args["threadId"] := 1

      send_request("continue", args)

      msg := expect_response("continue") | stop("continue failed")

      write("response:")
      write(tojson(msg))

      drain_messages(200)
      return self
   end

   method test_disconnect()
      local msg
      
      write("\nTEST disconnect\n")

      send_request("disconnect", table())

      msg := expect_response("disconnect") | stop("disconnect failed")

      write("response:")
      write(tojson(msg))

      return self
   end

   method run_tests()
      test_initialize()
      test_launch()
      test_configurationDone()
      test_threads()
      test_continue()
      test_disconnect()
      write("\nALL TESTS PASSED")
      return self
   end

   initially
      seq := 1

      if &features == ("MacOS" | "MS Windows NT") then
         udb_addr := "127.0.0.1"
      else
         udb_addr := ""

      udb_port := find_port()

end

procedure main(args)
   local client

   client := DAP_TestClient()
   client.start_adapter_and_connect()
   client.run_tests()
end

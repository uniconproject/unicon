end

procedure test_did_save_notification()
   local msg, params

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ]
   ]

   msg := JRPC_Message()
   assert_not_null(msg, "JRPC_Message() should create message") | fail

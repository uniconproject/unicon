import logger
import unittest

link ximage

global test_results
global msg_test_count, msg_pass_count, msg_fail_count
global verbose_mode  # Set to true for verbose output

# Convert test methods to procedures for UniconTestSuite
procedure test_jsonrpc_parsing()
   local msg, json_str

   # Test valid request
   json_str := "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",_
               \"params\":{\"processId\":1234}}"
   msg := JRPC_Message().parse_json(json_str)
   assert_not_null(msg, "parse_json should return message for valid request") | fail
   assert_equal(msg.get_kind(), "request", "Request message kind") | fail
   assert_equal(msg.get_id(), 1, "Request message ID") | fail
   assert_equal(msg.get_method(), "initialize", "Request method name") | fail

   # Test valid notification
   msg := &null
   json_str := "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didOpen\",_
               \"params\":{\"textDocument\":{\"uri\":\"file://test.icn\"}}}"
   msg := JRPC_Message().parse_json(json_str)
   assert_not_null(msg, "parse_json should return message for valid notification") | fail
   assert_equal(msg.get_kind(), "notification", "Notification message kind") | fail
   assert_equal(msg.get_method(), "textDocument/didOpen", "Notification method name") | fail

   # Test valid response
   msg := &null
   json_str := "{\"jsonrpc\":\"2.0\",\"id\":1,\"result\":_
               {\"capabilities\":{\"completionProvider\":true}}}"
   msg := JRPC_Message().parse_json(json_str)
   assert_not_null(msg, "parse_json should return message for valid response") | fail
   assert_equal(msg.get_kind(), "response", "Response message kind") | fail
   assert_equal(msg.get_id(), 1, "Response message ID") | fail
   return
end

procedure test_initialize_request()
   local msg, params, result

   params := [
      "processId": getpid();
      "rootUri": "file:///test";
      "capabilities": [
         "textDocument": [
            "completion": ["dynamicRegistration": "__false__"]
         ]
      ]
   ]

   msg := JRPC_Message().make_request(1, "initialize", params)
   assert_not_null(msg, "make_request should create message") | fail
   result := msg.make_result_response([
      "capabilities": [
         "completionProvider": ["triggerCharacters": [".", ":"]];
         "textDocumentSync": 1
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert{member(result.get_result(), "capabilities"), "Response should have capabilities"} | fail
   return
end

procedure test_completion_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ];
      "position": [
         "line": 0;
         "character": 5
      ]
   ]

   msg := JRPC_Message().make_request(2, "textDocument/completion", params)
   assert_not_null(msg, "make_request should create message") | fail
   result := msg.make_result_response([
      "isComplete": "__true__";
      "items": [
         [
            "label": "write";
            "kind": 1;
            "detail": "procedure"
         ]
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert{member(result.get_result(), "items"), "Response should have items"} | fail
   return
end

procedure test_hover_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ];
      "position": [
         "line": 0;
         "character": 10
      ]
   ]

   msg := JRPC_Message().make_request(3, "textDocument/hover", params)
   assert_not_null(msg, "make_request should create message") | fail
   result := msg.make_result_response([
      "contents": [
         [
            "language": "unicon";
            "value": "procedure main()\n    # Main procedure\nend"
         ]
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert{member(result.get_result(), "contents"), "Response should have contents"} | fail
   return
end

procedure test_definition_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ];
      "position": [
         "line": 0;
         "character": 10
      ]
   ]

   msg := JRPC_Message().make_request(4, "textDocument/definition", params)
   assert_not_null(msg, "make_request should create message") | fail
   result := msg.make_result_response([
      "uri": "file:///test.icn";
      "range": [
         "start": [
            "line": 0;
            "character": 0
         ];
         "end": [
            "line": 0;
            "character": 15
         ]
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert{member(result.get_result(), "uri"), "Response should have uri"} | fail
   return
end

procedure test_document_symbol_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ]
   ]

   msg := JRPC_Message().make_request(5, "textDocument/documentSymbol", params)
   assert_not_null(msg, "make_request should create message") | fail
   # LSP spec: documentSymbol returns a list directly, not a table with "symbols" key
   result := msg.make_result_response([
      [
         "name": "main";
         "kind": 12;
         "range": [
            "start": ["line": 0; "character": 0];
            "end": ["line": 0; "character": 15]
         ]
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert_equal(type(result.get_result()), "list", "Response result should be a list") | fail
   return
end

procedure test_folding_range_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ]
   ]

   msg := JRPC_Message().make_request(6, "textDocument/foldingRange", params)
   assert_not_null(msg, "make_request should create message") | fail
   # LSP spec: foldingRange returns a list directly, not a table with "ranges" key
   result := msg.make_result_response([
      [
         "startLine": 0;
         "endLine": 2
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert_equal(type(result.get_result()), "list", "Response result should be a list") | fail
   return
end

procedure test_formatting_request()
   local msg, params, result

   params := [
      "textDocument": [
         "uri": "file:///test.icn"
      ];
      "options": [
         "tabSize": 4;
         "insertSpaces": "__true__"
      ]
   ]

   msg := JRPC_Message().make_request(7, "textDocument/formatting", params)
   assert_not_null(msg, "make_request should create message") | fail
   # LSP spec: formatting returns a list directly, not a table with "edits" key
   result := msg.make_result_response([
      [
         "range": [
            "start": ["line": 0; "character": 0];
            "end": ["line": 0; "character": 0]
         ];
         "newText": "procedure main()\n    write(\"Hello\")\nend\n"
      ]
   ])
   assert_not_null(result, "make_result_response should create response") | fail
   assert_equal(result.get_kind(), "response", "Response kind") | fail
   assert_equal(type(result.get_result()), "list", "Response result should be a list") | fail
   return
end

procedure test_did_open_notification()
   local msg, params

   params := [
      "textDocument": [
         "uri": "file:///test.icn";
         "languageId": "unicon";
         "version": 1;
         "text": "procedure main()\n    write(\"Hello\")\nend\n"
      ]
   ]

   msg := JRPC_Message()
   assert_not_null(msg, "JRPC_Message() should create message") | fail
   msg.set_method("textDocument/didOpen")
   msg.set_params(params)

   assert_equal(msg.get_kind(), "notification", "Notification message kind") | fail
   assert_equal(msg.get_method(), "textDocument/didOpen", "Notification method name") | fail
   return
end

procedure test_did_change_notification()
   local msg, params

   params := [
      "textDocument": [
         "uri": "file:///test.icn";
         "version": 2
      ];
      "contentChanges": [
         [
            "text": "procedure main()\n    local x\n    x := 42\n    write(x)\nend\n"
         ]
      ]
   ]

   msg := JRPC_Message()
   assert_not_null(msg, "JRPC_Message() should create message") | fail
   msg.set_method("textDocument/didChange")
   msg.set_params(params)

   assert_equal(msg.get_kind(), "notification", "Notification message kind") | fail
   return
end


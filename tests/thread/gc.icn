#
# Long-running stress test for the garbage collector (concurrent threads).
#

global gsum
procedure main(argv)
   if not (&features == "concurrent threads") then
      stop("This program requires concurrent threads.")

   gsum := 0
   thrd := []

   if *argv>0 then
      n := integer(argv[1]) | stop("argument must be an integer")
   else
      n := 4

   x := 10^6
   d:= x / n

   write("running ", n , " thread(s) please wait... ")
   t := &now
   every i := !n do put(thrd, create suma(d, i ))
   every spawn(!thrd, 1M, 100K)
   every wait(!thrd)

   write("sum=",gsum+(x-d*n))
   writes("garbage collection =")

   # The list/table/set loop below is pointer-heavy: block memory tracks pointer width, so for the
   # same source, 64-bit builds typically use substantially more heap than 32-bit (often in the
   # ~2x ballpark). Detect what system we are running on and adjust for the number of &collections

   if (&features? if ="Arch" & tab(upto('_')) & move(1) then tab(0)) === "64" then
      write(if 190 < &collections < 210 then "OK" else &collections)
   else
      write(if 90 < &collections < 110 then "OK" else &collections)

end


procedure suma(n, id)
   local sum := 0, L, T, S
   static region
   initial region := mutex()

   every i := 1 to n do {
      sum +:= 1
      if i%100 = 1  then {
         L := []
         T := table()
         S := set()
         }

      put(L, i)
      T[i] := sum
      insert(S, i, sum)
      }

   critical region: gsum +:= sum
end

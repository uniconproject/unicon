end

procedure test_error_response()
   local msg, result

   msg := JRPC_Message().make_request(1, "test", [])
   assert_not_null(msg, "make_request should create message") | fail
   result := msg.make_error_response(-32601, "Method not found", "The method 'test' was not found")
   assert_not_null(result, "make_error_response should create error response") | fail
   assert_equal(result.get_kind(), "error", "Error response kind") | fail
   assert{member(result.get_error(), "code"), "Error should have code"} | fail
   assert_equal(result.get_error()["code"], -32601, "Error code should be -32601") | fail
   return
end

procedure test_malformed_message()
   local msg

   # Test invalid JSON - parse_json should return null for invalid JSON
   msg := &null
   msg := JRPC_Message().parse_json("{bad:json}")
   assert_null(msg, "parse_json should return null for invalid JSON") | fail

   # Test invalid JSONRPC
   msg := &null
   msg := JRPC_Message().parse_json("{\"max\" : 2}")
   assert_not_null(msg, "parse_json should return message for invalid JSONRPC") | fail
   assert_equal(msg.get_kind(), "unknown", "Invalid JSONRPC should have unknown kind") | fail

   # Test empty message
   msg := &null
   msg := JRPC_Message().parse_json("")
   assert_null(msg, "parse_json should return null for empty message") | fail
   return
end

# Wrapper class for backward compatibility
class LSPMessageTest : UniconTest()
   method register_tests()
      # Add this test file as a Test
      add_test("LSP Message Tests")

      # Add test sections
      add_test_section("JSON-RPC Message Parsing")
      add_test_case("test_jsonrpc_parsing", test_jsonrpc_parsing, "Test JSON-RPC message parsing")

      add_test_section("LSP Request Messages")
      add_test_case("test_initialize_request", test_initialize_request, "Test initialize request")
      add_test_case("test_completion_request", test_completion_request, "Test completion request")
      add_test_case("test_hover_request", test_hover_request, "Test hover request")
      add_test_case("test_definition_request", test_definition_request, "Test definition request")
      add_test_case("test_document_symbol_request", test_document_symbol_request,
                    "Test document symbol request")
      add_test_case("test_folding_range_request", test_folding_range_request,
                    "Test folding range request")
      add_test_case("test_formatting_request", test_formatting_request, "Test formatting request")

      add_test_section("LSP Notification Messages")
      add_test_case("test_did_open_notification", test_did_open_notification,
                    "Test didOpen notification")
      add_test_case("test_did_change_notification", test_did_change_notification,
                    "Test didChange notification")
      add_test_case("test_did_close_notification", test_did_close_notification,
                    "Test didClose notification")
      add_test_case("test_did_save_notification", test_did_save_notification,
                    "Test didSave notification")

      add_test_section("Error Handling")
      add_test_case("test_error_response", test_error_response, "Test error response")
      add_test_case("test_malformed_message", test_malformed_message,
                    "Test malformed message handling")
   end

end

$ifdef STANDALONE
procedure main(args)
   local test_suite, success, arg, output_style

   # Default to short style
   output_style := "short"

   every arg := !args do {
      if arg == ("-v" | "--verbose") then verbose_mode := 1
      if arg == ("-l" | "--long") then {
         output_style := "long"
         break
      }
      if arg == ("-d" | "--debug") then {
         output_style := "debug"
         break
      }
   }
   if getenv("ULSP_TEST_VERBOSE") then verbose_mode := 1

   Logger(if \verbose_mode then 8 else 6)
   test_suite := LSPMessageTest()
   success := test_suite.run_all_tests(output_style)

   if \success then
      exit(0)
   else
      exit(1)
end
$endif

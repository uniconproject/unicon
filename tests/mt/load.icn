#
# load.icn - compile, load, and run a program to verify that load() works
#
#   without -s, the name of the temp file will vary.
#
#   This probably won't work with a space in the path:

link io

# Resolve unicon without stat(&null).  &features is a generator; ? scans each line.
procedure compiler_for_mt_load()
   local p, path, exe
   exe := if find("NT", &features) then ".exe" else ""
   p := getenv("UNICON" | "UC")
   if \p & exists(p) then return p

   p := "../../bin/unicon" || exe
   if exists(p) then return p
   if path := (&features ? (="Binaries at " & tab(0))) then {
      if *path > 0 then {
         if not (path[-1] == "/" | path[-1] == "\\") then path ||:= "/"
         p := path || "unicon" || exe
         if exists(p) then return p
         }
      }
   return "unicon" || exe
end

procedure main()
    if not (&features == "multiple programs") then
        stop("This program requires multiple programs.")

    if find("NT", &features) then remove("a.exe")
    else remove("a")

    f := open("a.icn","w") | stop("can't write a.icn")
    write(f, "procedure main()\n_
                 write(\"hello, world\")\n_
              end")
    close(f)
    write("compiling a.icn")
    unicon := compiler_for_mt_load()
    if ss := system(unicon||" -s a.icn") then {
        if ss ~= 0 then stop("compile returned ", image(ss))
        }
    else stop("system(unicon a.icn) failed")

    write("loading a")
    if (x := load("a")) then write("loaded ", image(x))
    else stop("couldn't load(a)")

    write("running a")
    @x
    write("returned to parent, goodbye.")
    remove("a.icn")
    if find("NT", &features) then remove("a.exe")
    else remove("a")
end


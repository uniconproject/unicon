link ubug
$include "../../unicon/ytab_h.icn"
global yylineno, yycolno, yyfilename, tokflags
procedure main(argv)
   popt := 1
   t1 := &time 
   count := 0
   if argv[1] == "-p" then { popt := pop(argv) }
   yyin := open(argv[1]) | stop("can't open ", argv[1]|"no file given")
   yycolno := 1
   yylineno := 1
   yyfilename := argv[1]
   tokflags := 0
   yylex :=: yylex2

   while \(i := yylex()) > 0 do {
      if \popt then write(image(yytext), ": ", i)
      count +:= 1
      }
   close(yyin)
   t2 := &time
   write("processed ", count, " tokens"); # write(" in ", t2-t1, "ms")
end
